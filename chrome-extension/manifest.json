{
  "manifest_version": 3,
  "name": "AutoApply AI",
  "version": "2.0.0",
  "description": "Apply to jobs with AI — one click from hh.ru, staff.am, and any job board",
  "permissions": ["activeTab", "storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.hh.ru/*", "*://*.staff.am/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://autoapply-ai-vert.vercel.app/*",
    "https://*.hh.ru/*",
    "https://*.staff.am/*"
  ]
}
